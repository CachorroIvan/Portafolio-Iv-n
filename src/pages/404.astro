---

import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 - Not Found">
    <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4 relative z-10">
        
        <div class="absolute inset-0 z-[-1] flex items-center justify-center opacity-30 pointer-events-none">
            <div class="w-75 h-75 bg-[#ff007f] rounded-full blur-[120px] animate-pulse"></div>
            <div class="w-75 h-75 bg-[#00ffff] rounded-full blur-[120px] animation-delay-2000"></div>
        </div>

        <h1 class="text-8xl md:text-9xl font-black tracking-tighter text-transparent bg-clip-text bg-linear-to-r from-[#00ffff] via-[#9F47FF] to-[#ff007f] drop-shadow-[0_0_35px_rgba(0,255,255,0.2)] mb-4 animate-bounce">
            404
        </h1>

        <div class="bg-[#1a1941]/30 border border-white/10 backdrop-blur-md p-8 rounded-2xl max-w-md mx-auto shadow-2xl mb-8" data-aos="zoom-in">
            <div class="lang-block-es">
                <h2 class="text-xl md:text-2xl font-bold text-white mb-3">Ruta no encontrada</h2>
                
                <p class="text-gray-400 text-sm md:text-base leading-relaxed">
                    El proyecto, certificación o enlace que estás buscando no existe o se ha movido en la matriz.
                </p>
            </div>
            
            <div class="lang-block-en hidden">
                <h2 class="text-xl md:text-2xl font-bold text-white mb-3">Page Not Found</h2>
                <p class="text-gray-400 text-sm md:text-base leading-relaxed">
                    The project, certification, or link you are looking for does not exist or has been shifted in the matrix.
                </p>
            </div>
        </div>

        <a 
            id="back-home-btn"
            href="/" 
            class="px-8 py-4 rounded-full bg-linear-to-r from-[#00ffff] to-[#ff007f] text-[#0d0c1e] font-bold uppercase tracking-widest text-xs md:text-sm shadow-[0_0_20px_rgba(0,255,255,0.4)] hover:shadow-[0_0_30px_rgba(255,0,127,0.6)] hover:scale-105 active:scale-95 transition-all duration-300"
        >
            <span class="btn-text-es">Volver al Inicio</span>
            <span class="btn-text-en hidden">Return to Home</span>
        </a>
    </div>
</MainLayout>

<script is:inline>
    // Script inteligente para adaptar la UI según si venías navegando en inglés o español
    document.addEventListener('astro:page-load', () => {
        const isEnglish = window.location.pathname.startsWith('/en');
        const backBtn = document.getElementById('back-home-btn');

        if (isEnglish) {
            // Mostrar bloques en inglés
            document.querySelector('.lang-block-es')?.classList.add('hidden');
            document.querySelector('.lang-block-en')?.classList.remove('hidden');
            document.querySelector('.btn-text-es')?.classList.add('hidden');
            document.querySelector('.btn-text-en')?.classList.remove('hidden');
            
            // Redirigir el botón de regreso a la versión en inglés
            if (backBtn) backBtn.href = '/en';
        }
    });
</script>

<style>
    .animation-delay-2000 {
        animation-delay: 2s;
    }
</style>