---
const { currentLang = 'es' } = Astro.props;
const currentYear = new Date().getFullYear();

const footerText = {
    es: {
        bio: "Estudiante de Ingeniería en Computación en ESIME Culhuacán, IPN. Especializado en construir experiencias web modernas y Gestión de Proyectos TI.",
        navTitle: "Navegación", home: "Inicio", exp: "Experiencia", proj: "Proyectos", cert: "Certificaciones", stack: "Tech Stack", contact: "Contacto",
        built: "Desarrollado con"
    },
    en: {
        bio: "Computer Engineering Student at ESIME Culhuacan, IPN. Specializing in building modern web experiences and IT Project Management.",
        navTitle: "Navigation", home: "Home", exp: "Experience", proj: "Projects", cert: "Certifications", stack: "Service & Tech", contact: "Contact",
        built: "Built with"
    }
};
const t = footerText[currentLang];
---

<footer class="relative z-10 border-t border-white/10 bg-[#0d0c1e] pt-16 pb-8 mt-12">
    <div class="container mx-auto px-6 max-w-6xl">
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
            <div class="flex flex-col gap-4">
                <div class="flex items-center gap-3 mb-2">
                    <a href="/" class="block">
                        <img src="/logo-ig.svg" alt="Logo IG" class="w-10 h-10 object-contain drop-shadow-[0_0_10px_rgba(0,255,255,0.5)]" />
                    </a>
                    <h2 class="text-2xl font-bold text-white">Ivan <span class="text-[#ff007f]">González</span></h2>
                </div>
                <p class="text-gray-400 text-sm leading-relaxed max-w-sm">
                    {t.bio}
                </p>
            </div>

            <div class="flex flex-wrap items-start md:items-center gap-6">
                <h3 class="text-white font-bold tracking-widest uppercase text-xs sm:text-sm mb-4 sm:mb-6">{t.navTitle}</h3>
                <ul class="flex flex-wrap sm:flex-col gap-2 sm:gap-3 text-xs sm:text-sm text-gray-400 font-medium">
                    <li><a href="#inicio" class="hover:text-[#00ffff] transition-colors">{t.home}</a></li>
                    <li><a href="#experiencia" class="hover:text-[#00ffff] transition-colors">{t.exp}</a></li>
                    <li><a href="#proyectos" class="hover:text-[#00ffff] transition-colors">{t.proj}</a></li>
                    <li><a href="#certificaciones" class="hover:text-[#00ffff] transition-colors">{t.cert}</a></li>
                    <li><a href="#stack" class="hover:text-[#00ffff] transition-colors">{t.stack}</a></li>
                    <li><a href="#contacto" class="hover:text-[#00ffff] transition-colors">{t.contact}</a></li>
                </ul>
            </div>

            <div class="flex flex-col md:items-end gap-4">
                <div class="flex items-center gap-3 sm:gap-5">
                    <a href="https://github.com/CachorroIvan" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transform hover:scale-110 transition-all duration-300" aria-label="GitHub">
                        <svg class="w-5 sm:w-6 h-5 sm:h-6" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                    </a>
                    <a href="https://www.linkedin.com/in/arturo-iván-gonzález-delgado-76b739202/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#ff007f] transform hover:scale-110 transition-all duration-300" aria-label="LinkedIn">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </a>
                </div>
                <p class="text-sm text-gray-500 mt-2">
                    {t.built} <span class="text-[#ff007f] font-medium">Astro</span> & <span class="text-[#00ffff] font-medium">Tailwind CSS</span>.
                </p>
            </div>
            
        </div>

        <div class="h-px w-full bg-white/10 mb-8"></div>

        <div class="text-center">
            <p class="text-[9px] sm:text-xs tracking-widest text-gray-500 uppercase">
                © {currentYear} ARTURO IVÁN GONZÁLEZ DELGADO.
            </p>
        </div>
    </div>

    <a id="backToTopBtn" href="#inicio" class="fixed bottom-8 right-8 z-50 w-12 h-12 rounded-full bg-[#ff007f] text-white flex items-center justify-center hover:bg-[#ff007f]/80 hover:-translate-y-1 transition-all duration-300 shadow-[0_0_20px_rgba(255,0,127,0.4)] opacity-0 pointer-events-none translate-y-4" aria-label="Volver arriba">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
    </a>
    
    <script type="module">
        // Este script también lo pasamos a astro:page-load para asegurarnos que funcione al cambiar idioma
        document.addEventListener('astro:page-load', () => {
            const button = document.getElementById('backToTopBtn');
            if (!button) return;

            const toggleButton = () => {
                const visible = window.scrollY > 150;
                button.classList.toggle('opacity-100', visible);
                button.classList.toggle('opacity-0', !visible);
                button.classList.toggle('pointer-events-none', !visible);
                button.classList.toggle('translate-y-4', !visible);
            };

            toggleButton();
            window.addEventListener('scroll', toggleButton);
        });
    </script>
</footer>