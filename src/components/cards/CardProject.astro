---
export interface Props {
    title: string;
    description: string;
    tech: string[];
    link: string | string[];
    github: string | string[];
    status: string;
    color: string;
    gallery: string[];
    reverse?: boolean;
    lang?: 'en' | 'es';
}

const { title, description, tech, link, github, status, color, gallery, reverse = false, lang = 'es' } = Astro.props;

const labels = {
    gallery: lang === 'en' ? 'Gallery' : 'Galería',
    viewLive: lang === 'en' ? 'View Live' : 'Ver Live',
    deployment: lang === 'en' ? 'Deployment' : 'Despliegue',
    repository: lang === 'en' ? 'Repository' : 'Repositorio',
    techAlt: lang === 'en' ? 'Technology icon' : 'Icono de la tecnología',
};

const techIconMap: Record<string, string> = {
    'javascript': 'js.png',
    'css': 'css3.png',
    'astro': 'astro.png',
    'tailwindcss': 'tailwind.png',
    'vuejs': 'vue.png',
    'apirest': 'api.png',
    'sass': 'sass.png',
    'bootstrap': 'bootstrap.png',
    'dataviz': 'dataviz.png',
    'uiux': 'web.png'
};

const getTechIcon = (techName: string): string | undefined => {
    const normalized = techName
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '') 
        .replace(/[^a-z0-9]+/g, '');
    return techIconMap[normalized];
};

const linksArray = Array.isArray(link) ? link : [link];
const githubsArray = Array.isArray(github) ? github : [github];
---
<div data-aos="fade-up" class="h-full">
    <div  class="group relative rounded-2xl bg-[#1a1941]/20 border border-white/10 overflow-hidden backdrop-blur-sm hover:-translate-y-2 transition-transform duration-300 hover:shadow-[0_0_30px_rgba(0,255,255,0.1)] flex flex-col h-full">
        <div class={`w-2 h-full bg-linear-to-b ${color}`}></div>
        <div class={`p-6 md:p-8 flex flex-col md:flex-row ${reverse ? 'md:flex-row-reverse' : ''} grow`}>
            {gallery && gallery.length > 0 && (
                <div class="w-full md:w-72 lg:w-96 h-56 md:h-64 shrink-0 p-2 md:p-4 overflow-hidden">
                    <img 
                        src={gallery[0]} 
                        alt={`${title} preview`} 
                        class="w-full h-full object-cover rounded-lg hover:scale-105 hover:brightness-110 transition-all duration-500 ease-out cursor-pointer" 
                    />
                </div>
            )}
            <div class="flex flex-col grow">
                <div class="flex justify-between items-start mb-4">
                    <h3 class="text-xl font-bold text-white group-hover:text-[#00ffff] transition-colors">{title}</h3>
                </div>
                
                <span class="inline-block px-3 py-1 mb-4 rounded-full bg-white/5 border border-white/10 text-xs font-mono text-gray-300 w-fit">
                    {status}
                </span>

                <p class="text-gray-300 text-xs sm:text-sm leading-relaxed mb-4 grow">{description}</p>
                
                <div class="flex flex-wrap gap-1 sm:gap-2 mb-4">
                    {tech.map((t) => {
                        const icon = getTechIcon(t);
                        return (
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-[10px] sm:text-xs lg:text-sm font-medium rounded text-gray-300 bg-black/20 border border-white/5 hover:bg-white/10 transition-colors">
                                {icon && <img class="w-3.5 h-3.5 sm:w-4 sm:h-4 object-contain" src={`/img/icons/${icon}`} alt={`${labels.techAlt} ${t}`} loading="lazy" />}
                                {t}
                            </span>
                        );
                    })}
                </div>
                
                <div class="flex items-center gap-2 sm:gap-4 mt-auto pt-2 sm:pt-4 border-t border-white/10 flex-wrap">
                    <button 
                        class="open-gallery-btn text-xs sm:text-sm font-bold text-[#f51dd8] hover:text-white transition-colors flex items-center gap-1 sm:gap-2 px-2 sm:px-3 py-2 rounded-lg bg-[#ff007f]/10 hover:bg-[#ff007f]/30 whitespace-nowrap"
                        data-images={JSON.stringify(gallery)}
                    >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        {labels.gallery}
                    </button>

                    <div class="flex items-center gap-4 ml-auto">
                        
                        {linksArray.length === 1 ? (
                            linksArray[0] !== "#" && (
                                <a href={linksArray[0]} target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-[#ff03f2] hover:text-white transition-colors flex items-center gap-1">
                                    {labels.viewLive} <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                </a>
                            )
                        ) : (
                            <div class="relative group/live">
                                <button class="text-sm font-bold text-[#ff03f2] hover:text-white transition-colors flex items-center gap-1 cursor-pointer py-2">
                                    {labels.viewLive}
                                    <svg class="w-5 h-5 transition-transform duration-300 group-hover/live:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
                                </button>
                                <div class="absolute bottom-full right-0 mb-1 invisible opacity-0 translate-y-2 group-hover/live:visible group-hover/live:opacity-100 group-hover/live:translate-y-0 transition-all duration-300 flex flex-col bg-[#0d0c1e]/95 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_0_20px_rgba(255,3,242,0.2)] p-1.5 min-w-35 z-20">
                                    {linksArray.map((url, index) => (
                                        url !== "#" && (
                                            <a href={url} target="_blank" rel="noopener noreferrer" class="px-3 py-2 text-xs sm:text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 rounded-md transition-colors flex items-center justify-between gap-3 whitespace-nowrap">
                                                {labels.deployment} {index + 1}
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                            </a>
                                        )
                                    ))}
                                </div>
                            </div>
                        )}

                        {githubsArray.length === 1 ? (
                            githubsArray[0] !== "#" && (
                                <a href={githubsArray[0]} target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-[#00ffff] hover:text-white transition-colors flex items-center gap-1">
                                    GitHub <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                                </a>
                            )
                        ) : (
                            <div class="relative group/github">
                                <button class="text-sm font-bold text-[#00ffff] hover:text-white transition-colors flex items-center gap-1 cursor-pointer py-2">
                                    GitHub
                                    <svg class="w-4 h-4 transition-transform duration-300 group-hover/github:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
                                </button>
                                <div class="absolute bottom-full right-0 mb-1 invisible opacity-0 translate-y-2 group-hover/github:visible group-hover/github:opacity-100 group-hover/github:translate-y-0 transition-all duration-300 flex flex-col bg-[#0d0c1e]/95 backdrop-blur-xl border border-white/10 rounded-lg shadow-[0_0_20px_rgba(0,255,255,0.2)] p-1.5 min-w-35 z-20">
                                    {githubsArray.map((repo, index) => (
                                        repo !== "#" && (
                                            <a href={repo} target="_blank" rel="noopener noreferrer" class="px-3 py-2 text-xs sm:text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 rounded-md transition-colors flex items-center justify-between gap-3 whitespace-nowrap">
                                                {labels.repository} {index + 1}
                                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                                            </a>
                                        )
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>