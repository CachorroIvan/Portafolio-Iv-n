---
export interface Props {
    title: string;
    company: string;
    period: string;
    description: string;
    tech: string[];
    color: string;
    imge?: string;
}

const { title, company, period, description, tech, color, imge } = Astro.props;

const techIconMap: Record<string, string> = {
    'electron': 'electron.svg',
    'vuejs': 'vue.png',
    'nodejs': 'nodejs.png',
    'tailwindcss': 'tailwind.png',
    'javascript': 'js.png',
    'qa': 'qa.png',
    'auditoriaweb': 'auditoria.png',
    'uiux': 'web.png',
    'phpcollab': 'phpcollab.png',
    'c++': 'cpp.png',
    'python': 'python.png',
    'matlab': 'matlab.png',
    'electronica': 'electronica.png',
};

const getTechIcon = (techName: string): string | undefined => {
    const normalized = techName
        .toLowerCase()
        .normalize('NFD')
        .replace(/\p{Diacritic}/gu, '')
        .replace(/[^a-z0-9+]+/g, '');
    return techIconMap[normalized];
};
---
<div data-aos="fade-up" class="h-full">
    <div class="relative pl-8 md:pl-12">
        <div class={`absolute -left-2.25 top-1.5 w-4 h-4 rounded-full bg-linear-to-r ${color} shadow-[0_0_10px_currentColor]`}></div>
        
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-6 md:p-8 rounded-2xl hover:bg-white/10 transition-colors duration-300">
            <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-4">
                <div>
                    <h3 class="text-xl md:text-2xl font-bold text-white">{title}</h3>
                    <p class="text-lg font-medium text-transparent bg-clip-text bg-linear-to-r from-gray-300 to-gray-500">{company}</p>
                </div>
                
                <span class="w-fit self-start px-3 py-1 rounded-full bg-white/5 border border-white/10 text-sm font-mono text-gray-300 whitespace-nowrap">
                    {period}
                </span>
                
            </div>
            
            <p class="text-white leading-relaxed mb-6">
                {description}
            </p>
            
            <div class="flex flex-wrap gap-2">
                {tech.map((t) => {
                    const icon = getTechIcon(t);
                    return (
                        <span class="inline-flex items-center gap-2 px-3 py-1 text-xs font-medium rounded-xl bg-black/30 border border-white/5 text-gray-300">
                            {icon && <img class="w-7 h-7" src={`/img/icons/${icon}`} alt={`${t} icon`} loading="lazy" />}
                            {t}
                        </span>
                    );
                })}
            </div>
        </div>
    </div>
</div>