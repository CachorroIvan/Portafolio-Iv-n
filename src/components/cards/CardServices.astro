---
export interface Props {
    title: string;
    description: string;
    icon: string; 
    skills: { name: string; color: string }[];
    borderColor: string;
}

const { title, description, icon, skills, borderColor } = Astro.props;
---
<div class={`relative group rounded-2xl bg-white/5 border ${borderColor} p-6 backdrop-blur-sm hover:-translate-y-2 transition-all duration-300 hover:shadow-2xl overflow-hidden`}>
    <div class="absolute -right-10 -top-10 w-32 h-32 bg-white/5 rounded-full blur-2xl group-hover:bg-white/10 transition-colors duration-500"></div>

    <div class="w-12 h-12 rounded-lg bg-black/40 border border-white/10 flex items-center justify-center mb-6 text-white group-hover:scale-110 transition-transform duration-300" set:html={icon} />

    <h3 class="text-xl font-bold text-white mb-2">{title}</h3>
    <p class="text-gray-400 text-sm mb-6 leading-relaxed">
        {description}
    </p>

    <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
            <span class={`px-3 py-1 text-xs font-bold rounded-full bg-black/40 border border-white/10 ${skill.color}`}>
                {skill.name}
            </span>
        ))}
    </div>
</div>
