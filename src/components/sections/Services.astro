---
const techCategories = [
  {
    title: "Frontend & Ecosystem",
    description: "Creación de interfaces dinámicas, arquitectura de componentes y optimización de rendimiento (SEO y Core Web Vitals).",
    color: "from-yellow-400 to-orange-500",
    shadow: "hover:shadow-[0_0_30px_rgba(250,204,21,0.15)]",
    icons: [
      { name: "JavaScript", src: "/img/icons/js.png" },
      { name: "Vue.js", src: "/img/icons/vue.png" },
      { name: "React", src: "/img/icons/react.png" },
      { name: "Astro", src: "/img/icons/astro.png" },
    ]
  },
  {
    title: "UI & Estilos",
    description: "Diseño responsivo, maquetación moderna con utilidades y preprocesadores para estilos mantenibles y escalables.",
    color: "from-[#00ffff] to-blue-500",
    shadow: "hover:shadow-[0_0_30px_rgba(0,255,255,0.15)]",
    icons: [
      { name: "HTML5", src: "/img/icons/html.png" },
      { name: "CSS3", src: "/img/icons/css3.png" },
      { name: "Tailwind", src: "/img/icons/tailwind.png" },
      { name: "SASS", src: "/img/icons/sass.png" },
      { name: "Bootstrap", src: "/img/icons/bootstrap.png" },
    ]
  },
  {
    title: "Backend & Escritorio",
    description: "Desarrollo de lógica de servidor, aplicaciones robustas de consola y herramientas de ingeniería multiplataforma.",
    color: "from-[#ff007f] to-purple-500",
    shadow: "hover:shadow-[0_0_30px_rgba(255,0,127,0.15)]",
    icons: [
      { name: "Node.js", src: "/img/icons/nodejs.png" },
      { name: "Python", src: "/img/icons/python.png" },
      { name: "C++", src: "/img/icons/cpp.png" },
      { name: "C#", src: "/img/icons/csharp.png" },
      { name: ".NET Core", src: "/img/icons/dotnet.png" },
    ]
  },
  {
    title: "Herramientas & Datos",
    description: "Control de versiones, consumo de servicios RESTful y gestión de bases de datos relacionales para entornos de producción.",
    color: "from-teal-400 to-emerald-500",
    shadow: "hover:shadow-[0_0_30px_rgba(52,211,153,0.15)]",
    icons: [
      { name: "Git", src: "/img/icons/git.png" },
      { name: "GitHub", src: "/img/icons/github.png" },
      { name: "APIs REST", src: "/img/icons/api.png" },
      { name: "SQL Server", src: "/img/icons/sql.png" },
      { name: "VS Code", src: "/img/icons/vscode.png" },
    ]
  }
];

const learningGoals = [
  { name: "AWS", src: "/img/icons/aws.png" },
  { name: "Docker", src: "/img/icons/docker.png" },
  { name: "Azure", src: "/img/icons/azure.png" },
  { name: "Flutter", src: "/img/icons/flutter.png" },
  { name: "Kotlin", src: "/img/icons/kotlin.png" },
  { name: "Angular", src: "/img/icons/angular.png" },
];
---

<section id="stack" class="py-24 relative z-10">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="mb-16 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
          Tech <span class="text-transparent bg-clip-text bg-linear-to-r from-[#00ffff] to-[#ff007f]">Stack</span>
      </h2>
      <p class="text-gray-400 text-lg">Tecnologías y herramientas que utilizo para construir soluciones integrales.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {techCategories.map((category) => (
        <div class={`relative group rounded-2xl bg-white/5 border border-white/10 p-8 backdrop-blur-sm hover:-translate-y-2 transition-all duration-300 ${category.shadow} flex flex-col h-full`}>
            
            <h3 class={`text-2xl font-bold mb-3 text-transparent bg-clip-text bg-linear-to-r ${category.color}`}>
                {category.title}
            </h3>
            
            <p class="text-gray-200/80 text-sm leading-relaxed mb-8 grow">
                {category.description}
            </p>

            <div class="flex flex-wrap justify-center gap-8 mt-auto">
              {category.icons.map((icon) => (
                <div class="flex flex-col items-center group/icon relative">
                  <div class="w-24 h-24 p-2.5 rounded-xl bg-black/180 border border-white/10 transition-all duration-300">
                      <img 
                      src={icon.src} 
                      alt={icon.name} 
                      class="w-full h-full object-contain transform hover:scale-120 hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.6)] transition-all duration-300" 
                      />
                  </div>
                  <span class="absolute -bottom-10 opacity-0 group-hover/icon:opacity-100 transition-opacity text-xs font-mono text-white bg-[#0d0c1e] px-3 py-1.5 rounded-md border border-white/20 pointer-events-none z-50 whitespace-nowrap shadow-xl">
                    {icon.name}
                  </span>
                </div>
              ))}
            </div>

        </div>
      ))}
    </div>

    <div class="mt-12 relative group hover:-translate-y-2 transition-all duration-300 ${category.shadow} flex flex-col h-full`">
        <div class="absolute -inset-1 bg-linear-to-r from-[#00ffff]/20 via-[#ff007f]/20 to-purple-600/20 rounded-2xl blur-lg opacity-50 group-hover:opacity-100 transition duration-1000 group-hover:duration-300"></div>
        
        <div class="relative flex flex-col md:flex-row items-center justify-between p-6 md:p-8 rounded-2xl bg-[#0d0c1e]/80 backdrop-blur-xl border border-white/10 hover:border-white/20 transition-colors">
        
            <div class="mb-6 md:mb-0 md:mr-8 text-center md:text-left shrink-0">
                <h3 class="text-xl font-bold text-[#00ffff] mb-1">¿Que aprenderé despues? 🚀</h3>
                <p class="text-gray-400 text-sm">Expandiendo mis horizontes tecnológicos hacia Cloud y Móvil.</p>
            </div>

            <div class="flex flex-wrap justify-center md:justify-end gap-4">
                {learningGoals.map((goal) => (
                <div class="flex flex-col items-center group/learn cursor-help relative" title={`Learning ${goal.name}`}>
                    <div class="w-12 h-12 p-2.5 rounded-xl bg-black/40 border border-white/10 flex items-center justify-center transition-all duration-300 hover:-translate-y-1 hover:border-[#00ffff]/50">
                        <img 
                            src={goal.src} 
                            alt={goal.name} 
                            class="w-full h-full object-contain grayscale opacity-40 group-hover/learn:grayscale-0 group-hover/learn:opacity-100 transition-all duration-500" 
                        />
                    </div>
                </div>
                ))}
            </div>
        </div>
    </div>

  </div>
</section>