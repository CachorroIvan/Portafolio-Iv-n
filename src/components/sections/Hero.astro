<section id="inicio" class="min-h-[85vh] flex items-center justify-center pt-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center w-full container mx-auto px-6">
        <div class="flex flex-col gap-6 relative z-10">
            
            <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-[#00ffff]/30 bg-[#00ffff]/10 text-[#00ffff] text-sm font-medium w-fit shadow-[0_0_15px_rgba(0,255,255,0.15)]">
                <span class="relative flex h-3 w-3">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00ffff] opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-3 w-3 bg-[#00ffff]"></span>
                </span>
                Desarrollador Full Stack • ESIME IPN
            </div>

            <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight leading-tight">
                Construyendo el 
                <span class="text-gradient">Futuro Digital.</span>
            </h1>

            <p class="text-lg md:text-xl text-gray-400 max-w-xl leading-relaxed">
                Soy <strong class="text-white">Iván González</strong>, desarrollador Full Stack apasionado por crear experiencias modernas, aplicaciones escalables y soluciones con impacto real.
            </p>

            <div class="flex flex-wrap items-center gap-4 mt-4">
                <a href="#proyectos" class="px-8 py-3 rounded-lg bg-[#ff007f] text-white font-bold hover:bg-[#ff007f]/80 hover:shadow-[0_0_20px_rgba(255,0,127,0.5)] transition-all duration-300">
                    Ver Proyectos
                </a>
                <a href="https://github.com/CachorroIvan" target="_blank" rel="noopener noreferrer" class="px-8 py-3 rounded-lg border border-white/20 bg-white/5 hover:bg-white/10 backdrop-blur-sm text-white font-bold transition-all duration-300 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 22 22"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
                    GitHub
                </a>
                <a href="https://www.linkedin.com/in/arturo-iván-gonzález-delgado-76b739202/" target="_blank" rel="noopener noreferrer" class="px-8 py-3 rounded-lg border border-white/20 bg-white/5 hover:bg-white/10 backdrop-blur-sm text-white font-bold transition-all duration-300 flex items-center gap-2">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    LinkedIn
                </a>
            </div>
        </div>
        <div class="relative w-full max-w-[92vw] sm:max-w-xl p-5 sm:p-8 rounded-2xl border border-white/10 bg-[#0d0c1e]/60 backdrop-blur-xl shadow-2xl hover:-translate-y-2 transition-transform duration-500">
            <div class="absolute -inset-10 bg-cyan-500/10 blur-3xl rounded-full"></div>
            <div class="flex items-center gap-2 mb-4 sm:mb-6">
                <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            
            <div class="w-full overflow-x-auto pb-2">
<pre class="font-mono text-xs sm:text-sm md:text-base text-gray-300"><span class="text-[#ff007f]">const</span> <span class="text-white">developer</span> = &lbrace;
  <span class="text-[#00ffff]">name</span>: <span class="text-green-400">'Iván González'</span>,
  <span class="text-[#00ffff]">role</span>: <span class="text-green-400">'Full Stack'</span>,
  <span class="text-[#00ffff]">stack</span>: [
    <span class="text-green-400">'Astro'</span>, <span class="text-green-400">'Vue.js'</span>, <span class="text-green-400">'Node.js'</span>,
    <span class="text-green-400">'Electron'</span>, <span class="text-green-400">'Python'</span>, <span class="text-green-400">'C#'</span>,
    <span class="text-green-400">'C++'</span>, <span class="text-green-400">'React.js'</span>
  ],
  <span class="text-[#00ffff]">location</span>: <span class="text-green-400">'CDMX'</span>,
  <span class="text-[#00ffff]">status</span>: <span class="text-green-400">'Deploying ideas'</span>
&rbrace;;

<span class="text-gray-500">// Initialize career</span>
<span class="text-[#ff007f]">await</span> <span class="text-white">developer</span>.<span class="text-[#00ffff]">start</span>();</pre>
            </div>
        </div>
        
    </div>
</section>