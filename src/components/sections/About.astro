---
const technologies = [
  "Astro",
  "Vue",
  "React",
  "Node.js",
  "C#",
  "Python",
  "TailwindCSS",
  "Electron"
];

const techIconMap: Record<string, string> = {
  astro: 'astro.png',
  vue: 'vue.png',
  react: 'react.png',
  nodejs: 'nodejs.png',
  csharp: 'csharp.png',
  python: 'python.png',
  tailwindcss: 'tailwind.png',
  electron: 'electron.svg',
};

const getTechIcon = (techName: string): string | undefined => {
  const normalized = techName
    .toLowerCase()
    .normalize('NFD')
    .replace(/\p{Diacritic}/gu, '')
    .replace(/#/g, 'sharp')
    .replace(/[^a-z0-9+]+/g, '');

  return techIconMap[normalized];
};
---

<section id="sobre-mi" class="min-h-[85vh] flex items-center justify-center pt-20 relative">
    <div data-aos="fade-up" class="h-full">
    <div class="absolute inset-x-0 top-0 mx-auto w-120 h-120 bg-[#ff007f]/10 blur-[140px] rounded-full"></div>
    <div class="absolute inset-x-0 bottom-0 mx-auto w-120 h-120 bg-[#00ffff]/10 blur-[140px] rounded-full"></div>

    <div class="container mx-auto px-6 relative z-10">

        <div class="mb-14 max-w-3xl">
        <span class="text-[#00ffff] uppercase tracking-[0.25em] text-sm font-semibold">
            Sobre mí
        </span>

        <h2 class="text-4xl md:text-6xl font-bold text-white mt-3 leading-tight">
            Más que código,
            <span class="text-gradient block">creando experiencias.</span>
        </h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative flex justify-center">

            <div class="absolute -inset-4 w-85 h-85 md:w-105 md:h-105 bg-[#ff007f]/20 blur-[100px] rounded-full"></div>

            <div class="relative group max-w-105 w-full">

            <div class="absolute -left-3 -top-3 z-10 rounded-xl border border-white/10 bg-white/5 backdrop-blur-xl px-4 py-2 text-sm text-gray-900 shadow-xl">
                🚀 Full Stack Developer
            </div>

            <div class="overflow-hidden rounded-4xl border border-white/10 bg-[#0d0c1e]/60 backdrop-blur-xl shadow-2xl">
                <img
                id="parallax-img"
                src="/Ivan.png"
                alt="Iván González"
                class="w-full h-full min-h-80 object-cover transition-transform duration-500 group-hover:scale-105"
                />
            </div>

            <div class="mt-6 md:absolute -bottom-3 -right-3 md:mt-0 inline-flex flex-col gap-1 rounded-2xl border border-white/10 bg-[#111126]/90 px-5 py-4 text-sm text-gray-200 shadow-xl">
                <p class="text-gray-400">Actualmente aprendiendo</p>
                <p class="text-[#00ffff] font-semibold">
                React • Data Science • Arquitecturas modernas
                </p>
            </div>

            </div>
        </div>

        <div class="space-y-8">

            <div class="space-y-6">

            <p class="text-lg text-gray-300 leading-relaxed">
                Soy estudiante de Ingeniería en Computación en
                <span class="text-white font-semibold">ESIME Culhuacán</span>,
                apasionado por el desarrollo web, las aplicaciones de escritorio
                y las interfaces modernas.
            </p>

            <p class="text-lg text-gray-400 leading-relaxed">
                Disfruto construir proyectos que combinen diseño, rendimiento y
                experiencia de usuario, mientras continúo aprendiendo nuevas
                tecnologías y fortaleciendo mis habilidades como desarrollador Full
                Stack.
            </p>

            </div>

            <div class="flex flex-wrap gap-3">
            {technologies.map((tech) => {
                const icon = getTechIcon(tech);
                return (
                    <span class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-gray-200 transition-all duration-300 hover:border-[#ff007f]/40 hover:bg-[#ff007f]/10">
                        {icon && (
                            <img
                                class="w-5 h-5 object-contain"
                                src={`/img/icons/${icon}`}
                                alt={`${tech} icon`}
                                loading="lazy"
                            />
                        )}
                        {tech}
                    </span>
                );
            })}
            </div>

            <div class="grid gap-4 sm:grid-cols-2 pt-4">

            <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
                <h3 class="mb-2 text-white font-semibold">Desarrollo Web</h3>
                <p class="text-sm leading-relaxed text-gray-400">
                Interfaces modernas, experiencias dinámicas y aplicaciones escalables.
                </p>
            </div>

            <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
                <h3 class="mb-2 text-white font-semibold">Desktop Apps</h3>
                <p class="text-sm leading-relaxed text-gray-400">
                Aplicaciones de escritorio usando Electron, .NET y Python.
                </p>
            </div>

            </div>

        </div>
        </div>
    </div>
    </div>
</section>

<script is:inline>
    document.addEventListener('astro:page-load', () => {
        const parallaxImg = document.getElementById('parallax-img');
        
        if (!parallaxImg) return;

        window.addEventListener('scroll', () => {
            window.requestAnimationFrame(() => {
                const rect = parallaxImg.parentElement.getBoundingClientRect();
                const windowHeight = window.innerHeight;

                if (rect.top < windowHeight && rect.bottom > 0) {
                    const scrollPercentage = (rect.top / windowHeight);
                    
                    const yOffset = scrollPercentage * 35; 
                    
                    parallaxImg.style.transform = `translateY(${yOffset}px) scale(1.1)`;
                }
            });
        });
    });
</script>